# 环境变量配置文件
# 复制此文件为 .env.local 并填写实际的API密钥

# ========================================
# 魔塔（ModelScope）API配置
# ========================================
# 获取方式：https://modelscope.cn/my/myaccesstoken
# 注意：请勿将真实的 token 提交到代码仓库
MODELSCOPE_ACCESS_TOKEN=your_modelscope_token_here

# ========================================
# OCR识别模型配置（多模态模型）
# ========================================
# 推荐模型：
# - deepseek-ai/DeepSeek-OCR-2: DeepSeek OCR模型（推荐）
# - Qwen/Qwen2-VL-7B-Instruct: 视觉理解能力强
# - Qwen/Qwen3-VL-30B-A3B-Instruct: 高精度模型（当前使用）
# - Qwen/Qwen2-VL-72B-Instruct: 最高精度，速度慢
OCR_MODEL_ID=Qwen/Qwen3-VL-30B-A3B-Instruct

# ========================================
# 文字解析模型配置（文本模型）
# ========================================
# 推荐模型：
# - Qwen/Qwen2.5-72B-Instruct: 最高精度，推荐生产环境
# - Qwen/Qwen2.5-32B-Instruct: 平衡性能，推荐（当前使用）
# - Qwen/Qwen2.5-7B-Instruct: 速度快，成本低
# - qwen-turbo: 阿里云托管，最快（需要改用阿里云API）
TEXT_MODEL_ID=Qwen/Qwen2.5-32B-Instruct

# ========================================
# 模型参数配置
# ========================================
# OCR模型参数
OCR_TEMPERATURE=0.1
OCR_MAX_TOKENS=2048

# 文字解析模型参数
TEXT_TEMPERATURE=0.1
TEXT_MAX_TOKENS=1024

# ========================================
# 火山引擎（图生图 SeedEdit 3.0）
# ========================================
# 获取方式：https://console.volcengine.com/iam/keymanage/
# Access Key ID 和 Secret Access Key 均在「密钥管理」中创建
# 服务：cv（计算机视觉）/ 地域：cn-north-1
VOLCENGINE_ACCESS_KEY=your_volcengine_access_key_here
VOLCENGINE_SECRET_KEY=your_volcengine_secret_key_here

# ========================================
# 备选方案：百度OCR（如果不使用多模态）
# ========================================
# BAIDU_API_KEY=your_baidu_api_key
# BAIDU_SECRET_KEY=your_baidu_secret_key
